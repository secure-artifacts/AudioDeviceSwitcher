<Window x:Class="AudioDeviceSwitcher.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="音频切换助手 设置" SizeToContent="Height" Width="420" MaxHeight="900"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 通知 -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="通知" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <CheckBox x:Name="ChkNotifyProfile" Content="切换配置成功后提示" Margin="0,2"/>
            <CheckBox x:Name="ChkNotifyDevice" Content="检测到外部设备变更时提示" Margin="0,2"/>
            <CheckBox x:Name="ChkNotifyBluetooth" Content="蓝牙设备连接/断开时提示" Margin="0,2"/>
            <CheckBox x:Name="ChkNotifyDrift" Content="应用音频偏离配置时提示" Margin="0,2"/>
        </StackPanel>

        <Separator Grid.Row="1" Margin="0,12,0,12"/>

        <!-- 外观 -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="外观" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <CheckBox x:Name="ChkBlink" Content="警告文字闪烁动画" Margin="0,2"/>
        </StackPanel>

        <Separator Grid.Row="3" Margin="0,12,0,12"/>

        <!-- 集成 -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="集成" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <CheckBox x:Name="ChkVoicemeeterEnabled" Content="启用 Voicemeeter 集成" Margin="0,2"/>
            <TextBlock Text="未安装 Voicemeeter 时关闭，可避免无效的 DLL 加载和轮询。"
                       FontSize="11" Foreground="#777" Margin="20,0,0,0"/>
        </StackPanel>

        <Separator Grid.Row="5" Margin="0,12,0,12"/>

        <!-- 启动 -->
        <StackPanel Grid.Row="6">
            <TextBlock Text="启动" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <CheckBox x:Name="ChkStartMinimized" Content="启动时最小化到托盘" Margin="0,2"/>
            <Button Content="打开数据目录 (%AppData%\AudioDeviceSwitcher)" Padding="10,4" HorizontalAlignment="Left"
                    Margin="0,10,0,0" Click="OpenDataDir_Click"/>
        </StackPanel>

        <!-- 按钮 -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="取消" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click" IsCancel="True"/>
            <Button Content="保存" Padding="16,6" Click="Save_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
