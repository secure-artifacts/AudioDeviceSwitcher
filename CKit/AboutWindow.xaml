<Window x:Class="AudioDeviceSwitcher.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于 音频切换助手" SizeToContent="Height" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#FFFFFF">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="音频切换助手" FontSize="18" FontWeight="SemiBold" Foreground="#111827"/>
            <TextBlock Text="Audio Device Switcher" FontSize="12" Foreground="#6B7280" Margin="0,2,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,14,0,0">
            <TextBlock x:Name="VersionText" FontSize="12" Foreground="#374151"/>
            <TextBlock x:Name="CopyrightText" FontSize="12" Foreground="#6B7280" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,14,0,0">
            <TextBlock Text="快速切换 Windows 默认音频设备，支持配置 / 全局快捷键 / 蓝牙检测 / 应用级路由。"
                       FontSize="12" Foreground="#374151" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="打开日志文件" Padding="12,6" Margin="0,0,8,0" Click="OpenLog_Click"/>
            <Button Content="关闭" Padding="16,6" Click="Close_Click" IsDefault="True" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
